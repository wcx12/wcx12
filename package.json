{
  "name": "wcx12-homepage",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.23.1 <25"
  },
  "scripts": {
    "new:post": "node scripts/new-post.mjs",
    "sync:repos": "node scripts/sync-github-repos.mjs",
    "build:preview": "node scripts/build-blog.mjs --preview-drafts",
    "package:pages": "node scripts/package-pages.mjs",
    "preview:blog": "node scripts/serve-preview.mjs",
    "test:content": "node --test scripts/blog-content.test.mjs scripts/blog-discovery.test.mjs scripts/portfolio-ranking.test.mjs scripts/research-config-schema.test.mjs scripts/sync-github-repos.test.mjs",
    "test:homepage": "node --test scripts/homepage-runtime.test.mjs",
    "test:site": "node --test scripts/site-output.test.mjs",
    "test:pages": "node --test scripts/pages-artifact.test.mjs",
    "validate": "node scripts/validate-content.mjs && npm run test:content && npm run test:homepage && npm run test:site",
    "build:site": "node scripts/build-blog.mjs",
    "build:pages": "npm run build:site && npm run package:pages && npm run test:pages",
    "build:blog": "npm run build:site",
    "build": "npm run build:site"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "image-size": "2.0.2",
    "katex": "^0.16.47",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-katex": "npm:@vscode/markdown-it-katex@1.1.2"
  }
}
